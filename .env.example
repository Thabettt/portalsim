# Webhook Configuration
WEBHOOK_TARGET_URL=http://localhost:8080/webhook
SHARED_SECRET=your-shared-secret-change-in-production

# Database
DATABASE_URL=sqlite:///./university_portal.db

# Scheduler
SCHEDULER_TIMEZONE=UTC

# Webhook retry settings
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAYS=5,30,120

# App settings
APP_NAME=University Portal Simulator
DEBUG=true